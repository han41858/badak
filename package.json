{
	"name": "badak",
	"version": "1.0.6",
	"description": "node.js Server framework based on Promise and TypeScript",
	"exports": {
		"require": "./build/cjs/index.js",
		"import": "./build/esm/index.js"
	},
	"types": "build/index.d.ts",
	"main": "build/cjs/index.js",
	"scripts": {
		"prebuild": "rimraf ./build",
		"build:types": "tsc -p tsconfig.types.json",
		"build:cjs": "tsx ./scripts/create-package-json.ts cjs",
		"build:esm": "tsx ./scripts/create-package-json.ts esm",
		"build": "yarn build:types&&yarn build:cjs&&yarn build:esm",
		"postbuild": "tsc -p tsconfig.scripts.json&&node build/scripts/add-js-extensions",
		"test": "mocha",
		"lint": "eslint src spec"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/han41858/badak.git"
	},
	"keywords": [
		"server",
		"framework",
		"promise",
		"async",
		"await",
		"typescript"
	],
	"author": "han41858@gmail.com",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/han41858/badak/issues"
	},
	"homepage": "https://github.com/han41858/badak#readme",
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@stylistic/eslint-plugin-ts": "^4.4.1",
		"@types/chai": "^5.2.3",
		"@types/mocha": "^10.0.10",
		"@types/node": "24.10.10",
		"@types/supertest": "^6.0.3",
		"chai": "^6.2.2",
		"eslint": "^9.39.2",
		"eslint-plugin-chai-friendly": "^1.1.0",
		"globals": "^17.3.0",
		"mocha": "^11.7.5",
		"rimraf": "^6.1.2",
		"supertest": "^7.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	}
}
